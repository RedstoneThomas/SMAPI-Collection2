         {
            "LogName": "Satoru's Egg Festival Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/spring13",
            "Entries": {
                "Satoru": "It's a really cozy festival!$1#Don't you agree?$3",
                "Satoru_spouse": "Hmmm...$6#I'm thinking if I should join the egg hunt.$6"
            }
        },
        {
            "LogName": "Satoru's Luau Festival Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/summer11",
            "Entries": {
                "Satoru": "I hope the soup is really sweet! Will you be adding something to the soup?$1",
                "Satoru_spouse": "Hello, darling. Having fun?$8#Hm?$3"
            }
        },
        {
            "LogName": "Satoru's Dance of the Moonlight Jellies Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/summer28",
            "Entries": {
                "Satoru": "Watching the jellies dance is mesmerizing!$8",
                "Satoru_spouse": "There's something magical about this night, @. Maybe it's the jellies, or maybe it's just being here with you.$3"
            }
        },
        {
            "LogName": "Satoru's Spirit's Eve Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/fall27",
            "Entries": {
                "Satoru": "Are you scared?$3#Want me to protect you?$7#Hm?$8",
                "Satoru_spouse": "If you find yourself getting spooked, @, you know where to find me, love.$7#I'll always keep you safe.$1"
            }
        },
        {
            "LogName": "Satoru's Festival of Ice Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/winter8",
            "Entries": {
                "Satoru": "Are you going to try your luck at fishing?$7#Be careful not to slip on the ice!$8",
                "Satoru_spouse": "Don't worry about the ice, @.$7#I'll be right here to catch you if you fall.$1"
            }
        },
        {
            "LogName": "Satoru's Feast of the Winter Star Dialogue",
            "Action": "EditData",
            "Target": "Data/Festivals/winter25",
            "Entries": {
                "Satoru": "This year has gone by pretty fast.$6#Any new year wishes, @?$8",
                "Satoru_spouse": "Happy Winter Star, my love. This festival always reminds me of how lucky I am to have you in my life.$7#I love you.$1"
            }
        }
